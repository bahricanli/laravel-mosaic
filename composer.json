{
    "name": "bahricanli/laravel-mosaic",
    "description": "Mosaic Public API icin Laravel istemci kutuphanesi — kurumlarin sosyal medya istatistiklerini (takipci, gecmis, postlar, ozet) ceker.",
    "type": "library",
    "keywords": ["laravel", "mosaic", "social-media", "analytics", "api-client"],
    "license": "MIT",
    "authors": [
        {
            "name": "Bahri Meric Canli"
        }
    ],
    "require": {
        "php": ">=7.0",
        "guzzlehttp/guzzle": "^6.0 || ^7.0",
        "illuminate/support": "^5.5 || ^6.0 || ^7.0 || ^8.0 || ^9.0 || ^10.0 || ^11.0 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "BahriCanli\\Mosaic\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "BahriCanli\\Mosaic\\MosaicServiceProvider"
            ],
            "aliases": {
                "Mosaic": "BahriCanli\\Mosaic\\Facades\\Mosaic"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
